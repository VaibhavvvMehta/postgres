Question1 : 
Find the top 3 customers who spent the most money across all orders.

SQL
SELECT c.id, c.name, SUM(o.total_amount) AS total_spent
FROM customers c
JOIN orders o 
    ON o.customer_id = c.id
GROUP BY c.id, c.name
ORDER BY total_spent DESC
LIMIT 3;


Question 2 :
Find customers who have placed more than 3 orders.

SQL
SELECT c.id, c.name, COUNT(o.id) AS total_orders
FROM customers c
JOIN orders o 
    ON o.customer_id = c.id
GROUP BY c.id, c.name
HAVING COUNT(o.id) > 3;


Question 3:
Find products that have never been ordered.

SQL
SELECT p.id, p.name
FROM products p
LEFT JOIN order_items oi 
    ON oi.product_id = p.id
WHERE oi.product_id IS NULL;



Question 4:
Find customers whose total spending is greater than the average spending of all customers.

SQL
WITH customer_spending AS (
    SELECT 
        c.id,
        c.name,
        SUM(o.total_amount) AS total_spent
    FROM customers c
    JOIN orders o 
        ON o.customer_id = c.id
    GROUP BY c.id, c.name
)

SELECT *
FROM customer_spending
WHERE total_spent > (
    SELECT AVG(total_spent) FROM customer_spending
);


Question 5:
Find the top 2 products in each category based on total revenue.

SQL
SELECT *
FROM (
    SELECT 
        c.name AS category,
        p.name AS product,
        SUM(oi.quantity * oi.price_at_purchase) AS revenue,
        ROW_NUMBER() OVER (
            PARTITION BY c.id
            ORDER BY SUM(oi.quantity * oi.price_at_purchase) DESC
        ) AS rn
    FROM products p
    JOIN categories c 
        ON p.category_id = c.id
    JOIN order_items oi 
        ON oi.product_id = p.id
    GROUP BY c.id, c.name, p.id, p.name
) t
WHERE rn <= 2;


Question 6: 
Find the running cumulative revenue of orders by date.

SQL
SELECT 
    o.created_at,
    SUM(oi.quantity * oi.price_at_purchase) AS order_revenue,
    SUM(SUM(oi.quantity * oi.price_at_purchase)) 
        OVER (ORDER BY o.created_at) AS running_total
FROM orders o
JOIN order_items oi 
    ON oi.order_id = o.id
GROUP BY o.id, o.created_at
ORDER BY o.created_at;


Question 7:

Find the second highest revenue product in each category.

SQL
WITH product_revenue AS (
    SELECT
        c.id AS category_id,
        c.name AS category,
        p.id AS product_id,
        p.name AS product,
        SUM(oi.quantity * oi.price_at_purchase) AS revenue
    FROM products p
    JOIN categories c 
        ON p.category_id = c.id
    JOIN order_items oi 
        ON oi.product_id = p.id
    GROUP BY c.id, c.name, p.id, p.name
)

SELECT *
FROM (
    SELECT *,
           RANK() OVER (
               PARTITION BY category_id
               ORDER BY revenue DESC
           ) AS rnk
    FROM product_revenue
) t
WHERE rnk = 2;



Question 8:
Find customers who have purchased products from every category.

SQL
SELECT c.id, c.name
FROM customers c
JOIN orders o 
    ON o.customer_id = c.id
JOIN order_items oi 
    ON oi.order_id = o.id
JOIN products p 
    ON p.id = oi.product_id
GROUP BY c.id, c.name
HAVING COUNT(DISTINCT p.category_id) = (
    SELECT COUNT(*) FROM categories
);


Question 9: 
Find the 3 most recent orders for each customer.

SQL
SELECT *
FROM (
    SELECT 
        o.id,
        o.customer_id,
        o.created_at,
        ROW_NUMBER() OVER (
            PARTITION BY o.customer_id
            ORDER BY o.created_at DESC
        ) AS rn
    FROM orders o
) t
WHERE rn <= 3;


Question 10:

Find products whose total revenue is higher than the average revenue of all products.

SQL
WITH product_revenue AS (
    SELECT 
        p.id,
        p.name,
        SUM(oi.quantity * oi.price_at_purchase) AS revenue
    FROM products p
    JOIN order_items oi 
        ON oi.product_id = p.id
    GROUP BY p.id, p.name
),
avg_rev AS (
    SELECT AVG(revenue) AS avg_revenue
    FROM product_revenue
)

SELECT *
FROM product_revenue
WHERE revenue > (
    SELECT avg_revenue FROM avg_rev
);


